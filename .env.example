# Required: Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Scrape Schedule (Cron syntax: min hour day month day_of_week)
# Default: Monday and Thursday at 2:00 AM
SCRAPE_SCHEDULE="0 2 * * 1,4"

# Optional: Database URL (defaults to local sqlite)
# DATABASE_URL=sqlite:///./franklin_flyers.db
